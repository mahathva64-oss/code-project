name = input("Enter Employee Name: ")
hours = float(input("Enter Hours Worked: "))
wage = float(input("Enter Wage per Hour: "))
overtime = float(input("Enter Overtime Hours: "))
tax = float(input("Enter Tax Percentage: "))

basic_salary = hours * wage
overtime_pay = overtime * (1.5 * wage)
gross_salary = basic_salary + overtime_pay
tax_deduction = (tax / 100) * gross_salary
net_salary = gross_salary - tax_deduction

print("\n--- Salary Details ---")
print("Employee:", name)
print("Basic Salary:", basic_salary)
print("Overtime Pay:", overtime_pay)
print("Gross Salary:", gross_salary)
print("Tax Deduction:", tax_deduction)
print("Net Salary:", net_salary)
